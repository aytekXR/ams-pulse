{
  "$schema": "pulse-design-tokens",
  "version": "1.0.0",
  "font": {
    "sans": "'IBM Plex Sans', 'Helvetica Neue', Helvetica, Arial, sans-serif",
    "mono": "'IBM Plex Mono', ui-monospace, 'SF Mono', Menlo, monospace"
  },
  "type": {
    "display": { "size": 44, "line": 48, "weight": 700, "tracking": "-0.02em" },
    "h1": { "size": 32, "line": 40, "weight": 700, "tracking": "-0.02em" },
    "h2": { "size": 22, "line": 28, "weight": 600 },
    "h3": { "size": 16, "line": 24, "weight": 600 },
    "body": { "size": 14, "line": 22, "weight": 400 },
    "caption": { "size": 12, "line": 16, "weight": 500 },
    "label": { "size": 11, "line": 16, "weight": 500, "family": "mono", "tracking": "0.1em", "transform": "uppercase" },
    "metric": { "size": 40, "line": 44, "weight": 700, "numeric": "tabular-nums" }
  },
  "color": {
    "dark": {
      "bg": "#0A0E14",
      "surface": "#10161D",
      "raised": "#161E27",
      "border": "#1E2833",
      "borderStrong": "#2B3947",
      "textPrimary": "#E8EEF4",
      "textSecondary": "#9FB0C0",
      "textMuted": "#5C6F80",
      "signal": "#2CE5A7",
      "signalHover": "#4FEDB9",
      "onSignal": "#0A0E14",
      "healthy": "#2CE5A7",
      "warning": "#FFB224",
      "critical": "#FF5C68",
      "neutral": "#8296A8",
      "info": "#58A6FF"
    },
    "light": {
      "bg": "#F7F9FA",
      "surface": "#FFFFFF",
      "raised": "#F0F4F7",
      "border": "#D7DEE5",
      "borderStrong": "#C7D1DA",
      "textPrimary": "#10181F",
      "textSecondary": "#4A5B6B",
      "textMuted": "#6B7B88",
      "signal": "#087A59",
      "signalHover": "#07684C",
      "onSignal": "#FFFFFF",
      "healthy": "#0BA678",
      "warning": "#B45309",
      "critical": "#DC2626",
      "neutral": "#64748B",
      "info": "#1B5EAD"
    },
    "dataviz": ["#2CE5A7", "#58A6FF", "#A78BFA", "#F06BB2", "#FFB224", "#38D6E0", "#C4B26A", "#7C93AD"]
  },
  "space": [4, 8, 12, 16, 24, 32, 48, 64, 96],
  "radius": { "control": 8, "card": 12, "pill": 999 },
  "layout": {
    "appSidebar": 240,
    "appIconRail": 60,
    "marketingMaxWidth": 1160,
    "gridColumns": 12,
    "gutter": 24,
    "tableRowHeight": 40,
    "minTouchTarget": 44
  },
  "elevation": {
    "note": "Elevation by tone + border, not shadow. Shadows only on overlays.",
    "overlay": "0 24px 64px rgba(0,0,0,0.5)"
  },
  "motion": {
    "fast": "120ms ease-out",
    "base": "200ms ease-out",
    "note": "Live data updates fade, never slide. No bounce."
  }
}
