# Pulse — Caddy TLS terminator, PRODUCTION (real domain + Let's Encrypt).
#
# Used by deploy/docker-compose.prod-tls.yml. Differs from ./Caddyfile only by:
#   - NO 'tls internal' line  → Caddy auto-obtains public Let's Encrypt certs.
#   - the site addresses use {$PULSE_DOMAIN} (REQUIRED — no localhost fallback).
#
# Hostnames served (D-034 subdomains):
#   {$PULSE_DOMAIN}            apex → Pulse app (kept working)
#   pulse.{$PULSE_DOMAIN}      → Pulse app  (canonical subdomain)
#   ams.{$PULSE_DOMAIN}        → Ant Media Server panel (reverse-proxied to host:5080)
#   www.{$PULSE_DOMAIN}        → 301 redirect to apex
#
# Prerequisites before bringing this up / reloading:
#   1. DNS A records → the VPS public IP (161.97.172.146), propagated, for EACH of:
#        {$PULSE_DOMAIN}, www.{$PULSE_DOMAIN}, pulse.{$PULSE_DOMAIN}, ams.{$PULSE_DOMAIN}
#      (verify: dig @8.8.8.8 +short <name> == 161.97.172.146).
#   2. TCP :80 and :443 reachable from the internet (ACME HTTP-01 / TLS-ALPN).
#   3. PULSE_DOMAIN set in deploy/.env (e.g. PULSE_DOMAIN=beyondkaira.com).
#
# Optional: receive cert-expiry notices — add  email you@beyondkaira.com  to the
# global block below (Caddy works fine without it).

{
    # Global options.
    # For dry runs against Let's Encrypt STAGING (avoids rate limits), uncomment:
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# www → apex (301). Provisions a cert for www so it never serves a name mismatch.
www.{$PULSE_DOMAIN} {
    redir https://{$PULSE_DOMAIN}{uri} permanent
}

# ── Pulse app — apex + pulse.<domain> ────────────────────────────────────────
{$PULSE_DOMAIN}, pulse.{$PULSE_DOMAIN} {
    # No 'tls internal' → Caddy provisions a public Let's Encrypt certificate
    # for each name automatically on first request.

    # Beacon ingest — proxy /beacon/* to pulse:8091 so clients only need :443.
    # handle_path STRIPS /beacon: the SDK posts to {ingestUrl}/ingest/beacon and
    # the listener serves POST /ingest/beacon only, so ingestUrl for this deploy
    # is https://<domain>/beacon (plain `handle` forwarded /beacon/... -> 404).
    handle_path /beacon/* {
        reverse_proxy pulse:8091 {
            header_up X-Forwarded-For {remote_host}
            header_up X-Real-IP {remote_host}
        }
    }

    # AMS lifecycle webhooks — proxy /webhook/* to pulse:8092.
    # NOTE: the pulse webhook listener is OFF unless BOTH PULSE_WEBHOOK_ADDR=:8092
    # AND PULSE_WEBHOOK_SECRET are set in deploy/.env (fail-closed, serve.go:199).
    # Until then this route proxies to a closed port (502, not 404). After enabling,
    # verify end-to-end with a signed POST → 200 (see the next-session webhook item).
    handle /webhook/* {
        reverse_proxy pulse:8092 {
            header_up X-Forwarded-For {remote_host}
            header_up X-Real-IP {remote_host}
        }
    }

    # UI + API — proxy everything else to pulse:8090.
    handle {
        reverse_proxy pulse:8090 {
            header_up X-Forwarded-For {remote_host}
            header_up X-Real-IP {remote_host}
            header_up Host {host}
        }
    }

    # Security headers.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
        Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' wss://{$PULSE_DOMAIN} wss://pulse.{$PULSE_DOMAIN} https://{$PULSE_DOMAIN} https://pulse.{$PULSE_DOMAIN}; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
    }

    log {
        output stdout
        format json
        level INFO
    }
}

# ── Ant Media Server panel — ams.<domain> → {$AMS_UPSTREAM} ─────────────────
# AMS runs as the 'antmedia' container with --network host, serving plain HTTP on
# :5080. Caddy terminates TLS here so the panel password is encrypted in transit.
# Upstream is {$AMS_UPSTREAM} (default 161.97.172.146:5080; set AMS_UPSTREAM in
# deploy/.env — injected into this container via the environment: block in
# docker-compose.prod-tls.yml; consumed only by this ams.<domain> reverse_proxy).
# WebSocket upgrades are proxied automatically.
ams.{$PULSE_DOMAIN} {
    reverse_proxy {$AMS_UPSTREAM} {
        header_up X-Forwarded-For {remote_host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto https
    }

    # Minimal headers only — AMS ships its own UI/CSP; a strict policy breaks it.
    header {
        Strict-Transport-Security "max-age=31536000"
        -Server
    }

    log {
        output stdout
        format json
        level INFO
    }
}

# Yanki — site block for the SHARED pulse-prod Caddy (yanki.beyondkaira.com).
#
# The shared Caddy (container pulse-prod-caddy-1, the TLS terminator for every
# site on this VPS) mounts ONE file read-only:
#   ~/repo/ams-pulse/deploy/config/Caddyfile.prod  ->  /etc/caddy/Caddyfile
# There is NO import directory (verified 2026-07-10 by inspecting the container
# mounts) — to publish Yanki, add this block to that file (or add an `import`
# directive there plus a matching volume mount in ams-pulse's compose), then:
#     docker exec pulse-prod-caddy-1 caddy validate --config /etc/caddy/Caddyfile
#     docker exec pulse-prod-caddy-1 caddy reload   --config /etc/caddy/Caddyfile
# NEVER restart the shared Caddy — the other live sites terminate TLS on it.
#
# Upstreams are DOCKER NETWORK ALIASES, not host ports: the shared Caddy runs in
# a container, so host-loopback binds (127.0.0.1:...) are unreachable from it.
# docker-compose.prod.yml joins Yanki's web+api containers to the external
# network `pulse-prod_default` under the aliases below — the same pattern the
# shared Caddyfile already uses for its own app (`reverse_proxy pulse:8090`).
# Container-internal ports are fixed: web 8140, api 8141.
#
# One origin, path-routed, so there is NO CORS:
#   /api/* + /healthz  -> FastAPI  (alias yanki-api, container port 8141)
#   everything else    -> Next.js  (alias yanki-web, container port 8140)
yanki.beyondkaira.com {
	# API + health check -> backend
	@api path /api/* /healthz
	handle @api {
		reverse_proxy yanki-api:8141
	}

	# Everything else -> frontend
	handle {
		reverse_proxy yanki-web:8140
	}
}

# ── Bedirhan Demirel portfolio — bedirhandemirel.<domain> → host:3200 (Next.js next start) ──
#
# AUTHORITATIVE copy of the site block that fronts bedirhandemirel.beyondkaira.com
# (this file is what pulse-prod-caddy-1 mounts as /etc/caddy/Caddyfile). A mirror
# lives in the portfolio repo at ~/repo/bedo/deploy/Caddyfile.bedirhan.snippet so
# the routing is auditable from there — keep the two in sync. This Caddy also
# fronts the owner's OTHER production apps, so ALWAYS `caddy validate` before
# reloading — a bad config is rejected atomically, never dropped. NEVER restart
# the container; reload only. Full runbook: ~/repo/bedo/deploy/INSTALL.md.
#
# This block only terminates TLS + reverse-proxies. `header -Server` strips
# Caddy's Server: fingerprint from proxied responses (defense in depth; the
# global HTTP→HTTPS redirect's Server header is a separate shared-Caddy
# concern). Upstream = VPS public IP (161.97.172.146): the shared Caddy runs in
# a container and cannot reach the host's 127.0.0.1 — same proven host-process
# path as the brier block. That is why the app binds -H 0.0.0.0 and :3200 must
# be firewalled from the internet (INSTALL.md step 5).
#
# PREREQUISITE: a DNS A record bedirhandemirel.beyondkaira.com → 161.97.172.146
# must exist and be propagated BEFORE the Caddy reload — Let's Encrypt issuance
# fails without it (INSTALL.md step 1).
bedirhandemirel.{$PULSE_DOMAIN} {
    header -Server
    reverse_proxy 161.97.172.146:3200 {
        header_up X-Forwarded-For {remote_host}
        header_up X-Real-IP {remote_host}
        header_up Host {host}
    }
    log {
        output stdout
        format json
        level INFO
    }
}

matbu.{$PULSE_DOMAIN} {
    # No 'tls internal' -> Caddy auto-provisions a public Let's Encrypt cert.
    # NOTE (SPEC 11, Phase A): this puts matbu.beyondkaira.com in the public
    # certificate-transparency logs. Accepted for the dummy pilot; it is one more
    # reason real documents wait for Phase B.

    # ── PHASE A: basic_auth in front of the ENTIRE site (SPEC Section 11) ─────
    # One shared credential, so not even the app's own login page is exposed to
    # the internet. The app's session login still applies BEHIND this layer.
    #
    # !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    # !!  THE HASH BELOW IS A PLACEHOLDER. IT IS NOT A CREDENTIAL.          !!
    # !!  REPLACE IT BEFORE YOU VALIDATE OR RELOAD, OR THE SITE IS BROKEN.  !!
    # !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    #
    # Generate the bcrypt hash with the SHARED Caddy container (it is the same
    # binary that will parse it). Omit --plaintext so Caddy PROMPTS: that keeps
    # the password out of your shell history.
    #
    #   sudo docker exec -it pulse-prod-caddy-1 caddy hash-password
    #     Enter password:   <the shared pilot password>
    #     Confirm password: <again>
    #   -> prints  $2a$14$........................................................
    #
    # Paste that output as the second token below. The PLAINTEXT password never
    # enters this repo, a log, a commit, or a session summary — only the hash does
    # (and the hash only ever lives in the shared Caddyfile, not here).
    #
    # ── Directive name: `basic_auth` is correct here ─────────────────────────
    # The directive was RENAMED in Caddy 2.8 (`basicauth` -> `basic_auth`; the old
    # spelling still parses but is deprecated). The shared image is pinned by
    # digest, but ams-pulse/deploy/docker-compose.hardened.yml records what that
    # digest IS — `# caddy:2-alpine`, "Digest pinned 2026-07-08". Caddy 2.8 shipped
    # in May 2024, so a 2-alpine tag pulled in July 2026 is comfortably >= 2.8.
    # Hence `basic_auth`. If `sudo docker exec pulse-prod-caddy-1 caddy version`
    # ever contradicts that, the ONLY change needed is renaming this directive to
    # `basicauth` — the body is identical in both forms: <username> <bcrypt-hash>.
    basic_auth {
        evrak {$EVRAK_BASICAUTH_HASH}
    }
    # Caddy runs basic_auth BEFORE the handle blocks, so every route below —
    # including the 404 for /healthz — sits behind this credential.
    #
    # ── `caddy validate` will NOT catch a bad hash. Prove it with curl. ───────
    # basic_auth only checks that the username and password fields are non-empty at
    # provision time; the bcrypt hash itself is not parsed until an actual request
    # arrives. So the PLACEHOLDER above passes `caddy validate` AND passes
    # `caddy reload` — giving a green light on a site that 401s every credential,
    # forever. Validate proves syntax, not correctness.
    #
    # After the reload, prove the credential end-to-end (both curls, in order):
    #   curl -sS -o /dev/null -w '%{http_code}\n' https://matbu.beyondkaira.com
    #       -> 401   (no credential: correct, the basic_auth layer is live)
    #   curl -sS -o /dev/null -w '%{http_code}\n' -u evrak https://matbu.beyondkaira.com
    #       -> 200/302  (with the real password: you are through to the app)
    # A 401 on the SECOND curl, with the CORRECT password, means the hash above was
    # never replaced. That is the failure this comment exists to prevent.

    # ── /healthz is NOT publicly routed ───────────────────────────────────────
    # SPEC Section 7: /healthz exists for the Docker healthcheck and local probes
    # only. It is reachable from the host at 127.0.0.1:8150/healthz and from
    # inside the docker network at evrak-app:8000/healthz — but the public vhost
    # must never expose it. This handle block comes FIRST and is terminal, so the
    # path never reaches the reverse_proxy below.
    @healthz path /healthz /healthz/*
    handle @healthz {
        respond "Not Found" 404
    }

    # ── Everything else -> the app container, by docker network alias ─────────
    handle {
        reverse_proxy evrak-app:8000 {
            header_up X-Forwarded-For {remote_host}
            header_up X-Real-IP {remote_host}
            header_up Host {host}
        }
    }

    # ── Security headers ─────────────────────────────────────────────────────
    # `-Server` strips Caddy's Server: fingerprint from proxied responses.
    # NOTE: no Content-Security-Policy here ON PURPOSE. SPEC Section 14 / M8 puts
    # security headers (incl. a self-only CSP) in the APP, and two owners emitting
    # CSP means two conflicting policies. One owner: the app. Revisit at M8.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }

    log {
        output stdout
        format json
        level INFO
    }
}
