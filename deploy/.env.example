# Pulse — environment variable template.
#
# Copy this file to deploy/.env and fill in real values before starting
# the hardened stack.  deploy/.env is gitignored — never commit real secrets.
#
# Usage:
#   cp deploy/.env.example deploy/.env
#   # Edit deploy/.env with real values, then:
#   docker compose -p pulse-hardened \
#     -f deploy/docker-compose.yml \
#     -f deploy/docker-compose.hardened.yml \
#     --env-file deploy/.env \
#     up -d --build

# ── Pulse application secret ─────────────────────────────────────────────────
# 32-byte random hex string used for AES-GCM token encryption (min 16 bytes).
# Generate with:  openssl rand -hex 32
# Required in all non-dev deployments; validated at startup.
#
# _FILE convention (opt-in, for Docker secrets / secret managers):
#   Instead of PULSE_SECRET_KEY, set PULSE_SECRET_KEY_FILE=/run/secrets/pulse_secret_key
#   The file is read at startup; its content (trailing newline stripped) is used.
#   A missing or unreadable file causes a hard startup failure (fail-closed).
#   See deploy/docker-compose.secrets.yml + deploy/secrets/README.md.
#   Applies to all secret-bearing vars: PULSE_SECRET_KEY, PULSE_WEBHOOK_SECRET,
#   PULSE_AMS_LOGIN_PASSWORD, PULSE_METRICS_TOKEN, PULSE_AMS_AUTH_TOKEN.
PULSE_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# ── ClickHouse credentials ───────────────────────────────────────────────────
# These are used to create the ClickHouse user on first boot AND to
# authenticate the pulse/pulse-migrate services against ClickHouse.
# Use alphanumeric + underscore values (some CH builds reject special chars).
CLICKHOUSE_USER=pulse
CLICKHOUSE_PASSWORD=changeme-strong-password

# ── Meta store backend ───────────────────────────────────────────────────────
# PULSE_META selects the config/state store backend: sqlite (default) or postgres.
# Unset or empty falls back to sqlite.
# PULSE_META=sqlite

# PULSE_META_DSN is the SQLite file path (sqlite backend only).
# Default when unset: pulse_meta.db in the working directory.
# Has no effect when PULSE_POSTGRES_DSN is set (postgres backend takes precedence).
# PULSE_META_DSN=pulse_meta.db

# PULSE_POSTGRES_DSN, when set, overrides PULSE_META and PULSE_META_DSN and
# selects the postgres backend automatically.  PULSE_SECRET_KEY is REQUIRED
# for the postgres backend (AES-GCM encryption of credentials stored in PG).
# deploy/scripts/pulse-backup.sh backs up SQLITE ONLY; postgres operators
# must use pg_dump for backups.
# PULSE_POSTGRES_DSN=postgres://pulse:changeme@db:5432/pulse_meta?sslmode=disable

# ── TLS / domain ─────────────────────────────────────────────────────────────
# Local verify (base + hardened):  leave as 'localhost' — Caddy uses its internal CA.
# Production (base + hardened + prod-tls):  set to your real public domain and add
#   the prod-tls overlay, which binds Caddy on 0.0.0.0:80/443 and mounts
#   config/Caddyfile.prod (no 'tls internal') so Caddy obtains a real Let's Encrypt
#   cert. Prereqs: a DNS A record domain -> 161.97.172.146 (propagated) and :80/:443
#   reachable from the internet. e.g.:
#   PULSE_DOMAIN=beyondkaira.com
PULSE_DOMAIN=localhost

# ── Caddy AMS upstream (prod-tls overlay only) ───────────────────────────────
# Hostname or IP:port that Caddy reverse-proxies for ams.{PULSE_DOMAIN}.
# AMS binds 0.0.0.0:5080 on the host network; the VPS public IP is the default
# because the Caddy container reaches AMS via the host's network interface.
# Only consumed by the ams.{$PULSE_DOMAIN} block in deploy/config/Caddyfile.prod;
# injected via the environment: block in docker-compose.prod-tls.yml.
# AMS_UPSTREAM=161.97.172.146:5080

# ── Real AMS connection (used by the real-ams override, not mock-ams) ────────
# Uncomment and set when using a real Ant Media Server instead of mock-ams.
# PULSE_AMS_URL=http://your-ams-host:5080
# PULSE_AMS_AUTH_TOKEN=your-ams-rest-bearer-token
# PULSE_AMS_NODE_ID=standalone
# Cookie-session auth alternative to the bearer token (AMS console credentials;
# password supports the _FILE convention above, the email does not need it):
# PULSE_AMS_LOGIN_EMAIL=admin@example.com
# PULSE_AMS_LOGIN_PASSWORD=your-ams-console-password

# Comma-separated AMS application names to poll (e.g. live,vod).
# Empty or unset = poll all applications (default; wired in docker-compose.real-ams.yml).
# PULSE_AMS_APPLICATIONS=live

# Expected healthy ingest bitrate used by the health-score formula (kbps).
# Default: 2000. Set lower for camera pulls or low-bitrate sources (D-031).
# Wired via docker-compose.real-ams.yml — set there or here.
# PULSE_INGEST_TARGET_BITRATE_KBPS=2000

# ── Optional: Prometheus scrape auth ─────────────────────────────────────────
# PULSE_METRICS_TOKEN=changeme-metrics-scrape-token

# ── AMS webhook HMAC secret ──────────────────────────────────────────────────
# generate: openssl rand -hex 32
PULSE_WEBHOOK_SECRET=

# ── Optional: S3 export (Wave 2) ─────────────────────────────────────────────
# PULSE_S3_EXPORT_KEY_ID=AKIAIOSFODNN7EXAMPLE
# PULSE_S3_EXPORT_SECRET_KEY=changeme
# PULSE_S3_EXPORT_BUCKET=my-pulse-exports
# PULSE_S3_EXPORT_REGION=us-east-1

# ── Network / API security ───────────────────────────────────────────────────
# CORS allowed origins for /api/v1/* routes (comma-separated).
# Parsed from PULSE_CORS_ALLOWED_ORIGINS. Empty = no CORS headers emitted
# (same-origin requests still work). Example: https://admin.example.com
# PULSE_CORS_ALLOWED_ORIGINS=https://admin.example.com

# WebSocket origin patterns accepted by /live/ws (comma-separated).
# Parsed from PULSE_ALLOWED_WS_ORIGINS. Empty = same-origin only
# (nhooyr.io/websocket derives the pattern from the Host header).
# PULSE_ALLOWED_WS_ORIGINS=https://example.com

# Base URL used for alert deep-link URLs (optional).
# Read only by the YAML config loader (server/internal/config) — takes effect
# once the BE-02 YAML config path is wired; has no effect in the current
# loadEnvConfig() prod path.
# PULSE_BASE_URL=https://pulse.example.com

# ── License ──────────────────────────────────────────────────────────────────
# License key string (empty = Free tier). Read via os.Getenv in serve.go —
# no _FILE convention support; set directly here or inject via environment.
# PULSE_LICENSE_KEY=

# Override the embedded ed25519 CA public key used to verify license signatures
# (hex-encoded). Only needed if you are issued keys signed by a custom CA;
# leave unset to use the default Pulse CA (license.go:168).
# PULSE_LICENSE_PUBKEY=

# ── PDF report branding (S11 WO-A) ───────────────────────────────────────────
# Filesystem path to a PNG or JPEG logo embedded in generated PDF reports.
# Empty or unset = embedded default Pulse waveform logo.
# Unreadable or non-PNG/JPEG files are rejected at boot with a WARN (never crash).
# PULSE_REPORT_LOGO_PATH=

# ── Anomaly detector tuning (S11 WO-B) ───────────────────────────────────────
# Tick interval for the Welford baseline update loop (seconds). 0 = default 60s.
# Set to a lower value (e.g. 5) in CI to speed up anomaly rule integration tests.
# PULSE_ANOMALY_TICK_S=

# ── OIDC / SSO phase 1 (S11 WO-C) ────────────────────────────────────────────
# Set PULSE_OIDC_ISSUER to enable OIDC login at /auth/oidc/login.
# When unset, OIDC is fully disabled (no behaviour change to existing bearer auth).
#
# Required when PULSE_OIDC_ISSUER is set:
#   PULSE_OIDC_CLIENT_ID     — OAuth2 client ID registered with the provider.
#   PULSE_OIDC_CLIENT_SECRET — Client secret (supports _FILE convention).
#   PULSE_OIDC_REDIRECT_URL  — Full callback URL, e.g. https://pulse.example.com/auth/oidc/callback
#
# Optional:
#   PULSE_OIDC_GROUP_CLAIM   — id_token claim holding group membership (default: groups).
#   PULSE_OIDC_GROUP_ROLE_MAP — JSON: {"ops-admins":"admin","pulse-users":"viewer"}
#   PULSE_OIDC_DEFAULT_ROLE  — Role when no group matches. Empty (default) = fail-closed (403).
#                              Set to "viewer" to allow any authenticated OIDC user read-only access.
#   PULSE_OIDC_SESSION_TTL   — Session lifetime duration string (default: 24h). e.g. "48h".
#
# PULSE_OIDC_ISSUER=
# PULSE_OIDC_CLIENT_ID=
# PULSE_OIDC_CLIENT_SECRET=
# PULSE_OIDC_REDIRECT_URL=
# PULSE_OIDC_GROUP_CLAIM=groups
# PULSE_OIDC_GROUP_ROLE_MAP=
# PULSE_OIDC_DEFAULT_ROLE=
# PULSE_OIDC_SESSION_TTL=24h
