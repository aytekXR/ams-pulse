# Pulse quickstart — environment variables
# Copy this file to .env, fill in your values, then run install.sh (or
# `docker compose -f docker-compose.quickstart.yml --env-file .env up -d`).

# ── Security ───────────────────────────────────────────────────────────────────
# 32-byte hex key used for AES-256-GCM at-rest encryption of secrets.
# Generate with:  openssl rand -hex 32
# Keep this value private and stable — changing it invalidates stored secrets.
PULSE_SECRET_KEY=

# ── AMS connection ─────────────────────────────────────────────────────────────
# Full HTTP(S) URL of your Ant Media Server REST endpoint.
# Example: http://10.0.1.10:5080  or  https://ams.example.com
PULSE_AMS_URL=

# AMS admin email and password (used for cookie-session login, AMS EE).
PULSE_AMS_LOGIN_EMAIL=
PULSE_AMS_LOGIN_PASSWORD=

# ── License ────────────────────────────────────────────────────────────────────
# Optional — leave empty for Free tier (1 node, 7-day retention).
# Paste your trial or purchased key here to unlock Pro / Business / Enterprise.
# A trial key is included with the marketplace listing; you can also activate
# a key later via Settings → License in the UI once the stack is running.
PULSE_LICENSE_KEY=

# Official Pulse license verification key — do not change unless self-signing.
PULSE_LICENSE_PUBKEY=6403d7b49951d0220c7219e491b6525971edf10f0e64616b17023eab002ab4ba
